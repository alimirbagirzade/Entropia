# =============================================================================
# Entropia V18 — Environment Configuration (example)
# Copy to .env and adjust. NEVER commit a real .env. Secrets must not be logged.
# These defaults are tuned for the Docker Compose local stack.
# =============================================================================

# ---- Runtime ----
ENTROPIA_ENV=local                 # local | staging | production
ENTROPIA_LOG_LEVEL=INFO            # DEBUG | INFO | WARN | ERROR
ENTROPIA_LOG_FORMAT=json           # json | console

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_PATH=/api/v1
# Comma-separated allowed CORS origins for the web app.
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- PostgreSQL 16 (authoritative metadata store) ----
POSTGRES_USER=entropia
POSTGRES_PASSWORD=entropia
POSTGRES_DB=entropia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async driver for the app; Alembic derives a sync URL from these parts.
DATABASE_URL=postgresql+asyncpg://entropia:entropia@postgres:5432/entropia

# ---- Redis 7 (queue + lightweight cache) ----
REDIS_URL=redis://redis:6379/0
QUEUE_NAMESPACE=entropia

# ---- Object storage (S3-compatible; MinIO locally) ----
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=entropia
OBJECT_STORAGE_SECRET_KEY=entropia-secret
OBJECT_STORAGE_BUCKET=entropia-artifacts
OBJECT_STORAGE_USE_SSL=false

# ---- Workers ----
WORKER_CONCURRENCY=4
BACKTEST_WORKER_CONCURRENCY=2

# ---- Authentication ----
#
# TWO local profiles. Pick ONE — they are not interchangeable, and the UI follows
# whichever the API reports through GET /api/v1/meta (`auth_mode`).
#
# 1) NORMAL LOCAL BROWSER USE — AUTH_MODE=session  (this file's default)
#    Real Sign Up / Log In: argon2id credentials + opaque Bearer session tokens.
#    This is what you want when you open the app in a browser. REQUIRED for
#    staging/production.
#
# 2) DEVELOPER / TEST IMPERSONATION — AUTH_MODE=dev  (explicit opt-in)
#    No login at all: the API resolves identity from the X-Actor-Id header and
#    IGNORES session tokens outright. The UI hides Sign Up / Log In and shows the
#    "act as" control instead. Restricted to ENTROPIA_ENV=local — the app refuses
#    to start with AUTH_MODE=dev under staging/production (F-22 fail-closed).
#
# Do not mix them: under AUTH_MODE=dev a login would hand the browser a token the
# server discards, and every protected request would come back 401.
AUTH_MODE=session
AUTH_SESSION_TTL_MINUTES=720

# Static service-line credential for non-human runtimes (agent / scheduler /
# coordinator / workers). Session mode REQUIRES a non-empty value — internal
# services present it together with a non-human X-Actor-Id; empty disables the
# service line and those runtimes lose their identity. Never reuse a human
# session token here, and never commit a real value: scripts/bootstrap.sh (and
# update.sh / the .ps1 twins) generate a random one into your git-ignored .env.
ENTROPIA_SERVICE_TOKEN=

# First-Admin bootstrap: a sign-up matching this email becomes Admin — ONLY
# while no active Admin exists. Empty (default) disables the mechanism.
# Set this before your first session-mode signup to provision your own Admin.
ENTROPIA_BOOTSTRAP_ADMIN_EMAIL=

# Provision the credentialless `user_admin` fixture (X-Actor-Id only, no login).
# Unset follows AUTH_MODE: seeded in dev, skipped in session — an ACTIVE
# credentialless Admin permanently blocks first-Admin bootstrap. 1 forces it on,
# 0 forces it off.
# SEED_DEV_ADMIN=

# ---- Rate limiting (opt-in per deployment) ----
RATE_LIMIT_ENABLED=false
RATE_LIMIT_ANON_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=600
RATE_LIMIT_WRITE_PER_MINUTE=120

# ---- Frontend (Vite reads VITE_* at build/dev time) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---- Backup / DR (scripts/backup.sh; runbook: docs/BACKUP_DR.md) ----
# Local directory for `make backup` snapshots (git-ignored).
BACKUP_DIR=./backups
# Keep the newest N timestamped backups; older ones are pruned automatically.
BACKUP_RETENTION=7
