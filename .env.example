# =============================================================================
# Entropia V18 — Environment Configuration (example)
# Copy to .env and adjust. NEVER commit a real .env. Secrets must not be logged.
# These defaults are tuned for the Docker Compose local stack.
# =============================================================================

# ---- Runtime ----
ENTROPIA_ENV=local                 # local | staging | production
ENTROPIA_LOG_LEVEL=INFO            # DEBUG | INFO | WARN | ERROR
ENTROPIA_LOG_FORMAT=json           # json | console

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_PATH=/api/v1
# Comma-separated allowed CORS origins for the web app.
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- PostgreSQL 16 (authoritative metadata store) ----
POSTGRES_USER=entropia
POSTGRES_PASSWORD=entropia
POSTGRES_DB=entropia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async driver for the app; Alembic derives a sync URL from these parts.
DATABASE_URL=postgresql+asyncpg://entropia:entropia@postgres:5432/entropia

# ---- Redis 7 (queue + lightweight cache) ----
REDIS_URL=redis://redis:6379/0
QUEUE_NAMESPACE=entropia

# ---- Object storage (S3-compatible; MinIO locally) ----
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=entropia
OBJECT_STORAGE_SECRET_KEY=entropia-secret
OBJECT_STORAGE_BUCKET=entropia-artifacts
OBJECT_STORAGE_USE_SSL=false

# ---- Workers ----
WORKER_CONCURRENCY=4
BACKTEST_WORKER_CONCURRENCY=2

# ---- Authentication ----
# dev     : trust the X-Actor-Id header (local development + tests).
# session : real login — argon2id credentials + opaque Bearer session tokens.
AUTH_MODE=dev
AUTH_SESSION_TTL_MINUTES=720
# Static service-line credential for non-human runtimes (agent/scheduler).
# Empty disables the service line.
ENTROPIA_SERVICE_TOKEN=
# First-Admin bootstrap: a sign-up matching this email becomes Admin — ONLY
# while no active Admin exists. Empty (default) disables the mechanism.
ENTROPIA_BOOTSTRAP_ADMIN_EMAIL=

# ---- Rate limiting (opt-in per deployment) ----
RATE_LIMIT_ENABLED=false
RATE_LIMIT_ANON_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=600
RATE_LIMIT_WRITE_PER_MINUTE=120

# ---- Frontend (Vite reads VITE_* at build/dev time) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---- Backup / DR (scripts/backup.sh; runbook: docs/BACKUP_DR.md) ----
# Local directory for `make backup` snapshots (git-ignored).
BACKUP_DIR=./backups
# Keep the newest N timestamped backups; older ones are pruned automatically.
BACKUP_RETENTION=7
